{
  "name": "aps-ai-platform",
  "version": "1.1.0",
  "description": "APS 기반 BIM 뷰어 · 이슈/버전 관리 · AI 분석 통합 플랫폼",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "start:prod": "cross-env NODE_ENV=production node server.js",
    "syntax-check": "node -e \"require('fs').readdirSync('routes').filter(f=>f.endsWith('.js')).forEach(f=>require('child_process').execSync('node -c routes/'+f))\" && echo OK",
    "test": "echo \"테스트가 아직 구성되지 않았습니다\" && exit 0"
  },
  "keywords": [
    "aps",
    "autodesk",
    "bim",
    "forge-viewer",
    "ai-platform"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@aps_sdk/authentication": "^1.0.1",
    "@aps_sdk/data-management": "^1.1.4",
    "@aps_sdk/model-derivative": "^1.2.1",
    "@aps_sdk/oss": "^1.3.3",
    "axios": "^1.13.6",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-formidable": "^1.2.0",
    "express-session": "^1.19.0",
    "handlebars": "^4.7.8",
    "multer": "^2.1.1",
    "ollama": "^0.6.3",
    "puppeteer": "^24.40.0"
  }
}
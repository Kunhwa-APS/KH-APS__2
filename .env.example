# ─────────────────────────────────────────────────────────────
# APS AI Platform — 환경 변수 템플릿
# .env 파일로 복사 후 실제 값을 입력하세요.
# ─────────────────────────────────────────────────────────────

# ─── [필수] Autodesk Platform Services ────────────────────────
# https://aps.autodesk.com/myapps 에서 발급
APS_CLIENT_ID="your-client-id-here"
APS_CLIENT_SECRET="your-client-secret-here"
APS_CALLBACK_URL="http://localhost:8080/api/auth/callback"

# ─── [필수] 세션 시크릿 (임의의 긴 문자열) ────────────────────
SERVER_SESSION_SECRET="change-this-to-a-long-random-string"

# ─── [선택] 실행 환경 ─────────────────────────────────────────
NODE_ENV=development      # development | production
PORT=8080

# ─── [선택] 지도 API 키 ───────────────────────────────────────
# VWorld: https://www.vworld.kr  (한국 지도/타일/지오코딩용)
VWORLD_API_KEY=""
# Google Maps: https://console.cloud.google.com  (VWorld 폴백)
GOOGLE_MAPS_API_KEY=""

# ─── [선택] AI 프로바이더 ─────────────────────────────────────
# openai | gemini | ollama — 하나를 선택
AI_PROVIDER=gemini

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=""
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=""

# Ollama (로컬 LLM — https://ollama.com)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
